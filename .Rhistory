# 1. Değişken Tanımlama
my_first <- "Basar"
my_birth_year <- 2003
# 2. k Değeri Hesaplama
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
print(paste("Hesaplanan k değeri:", k))
# 3. Orijinal Veriden k Satır Gösterimi
if (k %% 2 == 0) {
head(polls_us_election_2016, k)
} else {
tail(polls_us_election_2016, k)
}
# 4. NA Değerleri Analizi
print(paste("Toplam NA sayısı:", sum(is.na(polls_us_election_2016))))
na_per_col <- sort(colSums(is.na(polls_us_election_2016)), decreasing = TRUE)
head(na_per_col, 8)
# 5. NA Değerlerini Değiştirme
new_data <- polls_us_election_2016
for (i in names(new_data)) {
if (is.numeric(new_data[[i]])) {
