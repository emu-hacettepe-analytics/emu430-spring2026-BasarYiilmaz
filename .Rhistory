library(dslabs)
data("polls_us_election_2016")
# 1. Değişken Tanımlama
my_first <- "Basar"
my_birth_year <- 2004
# 2. k Değeri Hesaplama
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
print(paste("Hesaplanan k değeri:", k))
# 3. Orijinal Veriden k Satır Gösterimi
if (k %% 2 == 0) {
head(polls_us_election_2016, k)
} else {
tail(polls_us_election_2016, k)
}
# 4. NA Değerleri Analizi
print(paste("Toplam NA sayısı:", sum(is.na(polls_us_election_2016))))
na_per_col <- sort(colSums(is.na(polls_us_election_2016)), decreasing = TRUE)
head(na_per_col, 8)
# 5. NA Değerlerini Değiştirme
new_data <- polls_us_election_2016
for (i in names(new_data)) {
if (is.numeric(new_data[[i]])) {
new_data[[i]][is.na(new_data[[i]])] <- my_birth_year + k
} else if (is.character(new_data[[i]]) || is.factor(new_data[[i]])) {
new_data[[i]][is.na(new_data[[i]])] <- paste0(my_first, k)
}
}
# 6. Yeni Veri Çerçevesi Çıktıları
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
# Final kontroller
print(paste("Yeni verideki kalan NA sayısı:", sum(is.na(new_data))))
anyNA(new_data)
#| label: assignment1-analysis
#| message: false
# Gerekli kütüphaneyi yükle ve veriyi çek
library(dslabs)
data("polls_us_election_2016")
# 1. Değişken Tanımlama
my_first <- "Basar"
my_birth_year <- 2004
# 2. k Değeri Hesaplama
# k = (5 + 2004) %% 15 + 8 = 2009 %% 15 + 8 = 14 + 8 = 22
k <- (nchar(my_first) + my_birth_year) %% 15 + 8
print(paste("Hesaplanan k değeri:", k))
# 3. Orijinal Veriden k Satır Gösterimi
# k=22 çift sayı olduğu için head() kullanılmaktadır
if (k %% 2 == 0) {
head(polls_us_election_2016, k)
} else {
tail(polls_us_election_2016, k)
}
# 4. NA Değerleri Analizi
total_na <- sum(is.na(polls_us_election_2016))
print(paste("Toplam NA sayısı:", total_na))
# Sütun başına NA sayılarını sırala ve ilk 8'i göster
na_per_col <- sort(colSums(is.na(polls_us_election_2016)), decreasing = TRUE)
head(na_per_col, 8)
# 5. NA Değerlerini Değiştirme
# Orijinal veriyi korumak için yeni bir nesne oluşturuyoruz
new_data <- polls_us_election_2016
for (i in names(new_data)) {
if (is.numeric(new_data[[i]])) {
# Sayısal ise: doğum yılı + k
new_data[[i]][is.na(new_data[[i]])] <- my_birth_year + k
} else if (is.character(new_data[[i]]) || is.factor(new_data[[i]])) {
# Karakter/Faktör ise: isim + k
new_data[[i]][is.na(new_data[[i]])] <- paste0(my_first, k)
}
}
# 6. Yeni Veri Çerçevesi Çıktıları
# Kurala göre k satırı göster (k=22 çift -> head)
if (k %% 2 == 0) {
head(new_data, k)
} else {
tail(new_data, k)
}
# Final Kontroller
print(paste("Yeni verideki kalan NA sayısı:", sum(is.na(new_data))))
anyNA(new_data)
#| label: assignment1-analysis
#| message: false
